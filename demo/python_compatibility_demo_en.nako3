PRINT "Plot ID: {line_plot["plot"]["id"]}"
PRINT "Plot type: {line_plot["plot"]["type"]}"
PRINT "Title: {line_plot["plot"]["title"]}"
PRINT "Size: {line_plot["plot"]["figsize"]を「,」で区切って表示}"

# Scatter plot test
