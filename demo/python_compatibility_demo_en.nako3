  {"features": [1, 2], "label": 0},
  {"features": [2, 3], "label": 1},
  {"features": [3, 4], "label": 1},
  {"features": [4, 5], "label": 0},
  {"features": [5, 6], "label": 1}
]
svm_model = TRAIN_SCIKIT_LEARN_MODEL ml_data "svm"
PRINT "SVM model training: {svm_model["message"]}"
PRINT "Model ID: {svm_model["model"]["id"]}"
PRINT "Algorithm: {svm_model["model"]["algorithm"]}"
PRINT "Accuracy: {svm_model["model"]["accuracy"]}%"
PRINT "Precision: {svm_model["model"]["precision"]}%"
PRINT "Recall: {svm_model["model"]["recall"]}%"
PRINT "F1 Score: {svm_model["model"]["f1_score"]}%"
PRINT "Training time: {svm_model["model"]["training_time"]}ms"

# Random Forest test
rf_model = TRAIN_SCIKIT_LEARN_MODEL ml_data "random_forest"
PRINT "Random Forest: {rf_model["message"]}"
PRINT "Accuracy: {rf_model["model"]["accuracy"]}%"

