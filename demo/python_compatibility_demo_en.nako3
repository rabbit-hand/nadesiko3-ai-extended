# --- Python Code Execution ---
DISPLAY "21. Testing Python code execution..."
python_code = """
import numpy as np
import pandas as pd

# Create NumPy array
arr = np.array([1, 2, 3, 4, 5])
print(f"NumPy array: {arr}")
print(f"Mean: {np.mean(arr)}")

# Create Pandas DataFrame
data = {'A': [1, 2, 3], 'B': [4, 5, 6]}
df = pd.DataFrame(data)
print(f"DataFrame:\\n{df}")

print("Python code execution completed!")
"""
code_execution = EXECUTE_PYTHON_CODE python_code
PRINT "Python code execution: {code_execution["message"]}"
PRINT "Execution ID: {code_execution["result"]["id"]}"
PRINT "Execution time: {code_execution["result"]["execution_time"]}ms"
PRINT "Memory usage: {code_execution["result"]["memory_usage"]}MB"
