# --- 実用的な例：ドローン飛行ログ ---
「13. 実用的な例：ドローン飛行ログ...」と表示。

飛行ログ = []
5回
  # 最新の飛行データを取得
  最新飛行データ = 飛行データ取得
  
  # ログデータを作成
  ログエントリー = {
    "timestamp": 最新飛行データ["timestamp"],
    "altitude": 最新飛行データ["position"]["altitude"],
    "speed": 最新飛行データ["motion"]["velocity"]["total"],
    "battery": 最新飛行データ["flight"]["battery"],
    "heading": 最新飛行データ["orientation"]["heading"]
  }
  
  飛行ログにログエントリーを追加
  1000を待つ
ここまで

「飛行ログ（5回分）:」と表示。
飛行ログを反復
  時刻 = 対象["timestamp"]
  高度 = 対象["altitude"]
  速度 = 対象["speed"]
  バッテリー = 対象["battery"]
  方位 = 対象["heading"]
  「  {時刻}: 高度{高度}m, 速度{速度}m/s, バッテリー{バッテリー}%, 方位{方位}°」と表示。
ここまで。

「」と表示。

# --- 英語モードでの使用例 ---
「14. 英語モードでの使用例...」と表示。
「言語モード設定」に「english」

# 英語でドローンセンサー検出
english_sensors = DISCOVER_DRONE_SENSORS
PRINT "English Drone Sensors:"
PRINT "Sensors found: {english_sensorsのキー数}"

# 英語でジャイロデータ取得
gyro_data = GET_GYRO_DATA
PRINT "Gyro - Roll: {gyro_data["roll"]}°, Pitch: {gyro_data["pitch"]}°, Yaw: {gyro_data["yaw"]}°"

# 英語でGPSデータ取得
gps_data = GET_GPS_DATA
PRINT "GPS - Lat: {gps_data["latitude"]}, Lon: {gps_data["longitude"]}, Alt: {gps_data["altitude"]}m"

# 英語でモーター回転数取得
motor_rpm = GET_MOTOR_RPM
PRINT "Motors - Total: {motor_rpm["summary"]["total"]}, Avg RPM: {motor_rpm["summary"]["averageRPM"]}"

# 英語で高度データ取得
altitude_data = GET_ALTITUDE_DATA
PRINT "Altitude - Height: {altitude_data["altitude"]}m, Pressure: {altitude_data["pressure"]}hPa"

# 英語でドローン制御
takeoff_result = CONTROL_DRONE "takeoff"
PRINT "Takeoff: {takeoff_result["message"]}"

「」と表示。

