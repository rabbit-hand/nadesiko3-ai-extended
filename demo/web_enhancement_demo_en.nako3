}
circle_draw = EXECUTE_CANVAS_DRAW circle_draw_command "main_canvas"
PRINT "Circle drawing: {circle_draw["message"]}"
PRINT "Center coordinates: ({circle_draw["draw_result"]["parameters"]["center_x"]}, {circle_draw["draw_result"]["parameters"]["center_y"]})"
PRINT "Radius: {circle_draw["draw_result"]["parameters"]["radius"]}"

# Text drawing
