PRINT "Select box: {select_creation["message"]}"
PRINT "Options: {select_creation["component"]["properties"]["options"]を「,」で区切って表示}"
PRINT "Multiple: {select_creation["component"]["properties"]["multiple"]}"

DISPLAY ""

# --- Canvas Drawing ---
DISPLAY "5. Executing canvas drawing..."
line_draw_command = {
  "type": "draw_line",
  "parameters": {
    "start_x": 10,
    "start_y": 10,
    "end_x": 100,
    "end_y": 100,
    "color": "#ff0000",
    "width": 2
  }
}
line_draw = EXECUTE_CANVAS_DRAW line_draw_command "main_canvas"
PRINT "Line drawing: {line_draw["message"]}"
PRINT "Draw ID: {line_draw["draw_result"]["id"]}"
PRINT "Operation type: {line_draw["draw_result"]["operation"]}"
PRINT "Execution time: {line_draw["draw_result"]["execution_time"]}ms"
PRINT "Rendering quality: {line_draw["draw_result"]["rendering_quality"]}%"

# Circle drawing
