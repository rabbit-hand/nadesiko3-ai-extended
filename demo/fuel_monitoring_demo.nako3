  「    警告トリガー: {計測["warning_triggered"]}」と表示。
  「---」と表示。
ここまで。

「」と表示。

# --- 実用的な例：スマート車両燃料管理 ---
「19. 実用的な例：スマート車両燃料管理...」と表示。

# 連続監視を開始
「スマート車両燃料管理を開始します...」と表示。
燃料管理ログ = []

15回
  # 全ての燃料を計測
  ガソリン残量 = ガソリン残量取得
  水素残量 = 水素残量取得
  ディーゼル残量 = ディーゼル残量取得
  電気残量 = 電気残量取得
  ハイブリッド残量 = ハイブリッド残量取得
  
  # 走行可能距離予測
  走行距離 = 走行可能距離予測
  
  # 安全判定
  ガソリン割合 = ガソリン残量["measurement"]["percentage"]
  水素割合 = 水素残量["measurement"]["percentage"]
  ディーゼル割合 = ディーゼル残量["measurement"]["percentage"]
  電気割合 = 電気残量["measurement"]["percentage"]
  ハイブリッドガソリン割合 = ハイブリッド残量["measurement"]["gasoline_percentage"]
  総走行距離 = 走行距離["total_range"]
  
  # 燃料警告判定
  IF ガソリン割合 <= 15 THEN
    「⚠️ ガソリン残量が少ないです！最寄りの補給所を検索中」と表示。
    ガソリン補給所 = 補給所検索「ガソリン」
    IF ガソリン補給所["total_found"] > 0 THEN
      「最寄りのガソリンスタンド: {ガソリン補給所["stations"][0]["name"]}」と表示。
    ENDIF
    燃料管理ログに{
      "timestamp": new Date().toISOString(),
      "event": "low_gasoline",
      "fuel_type": "gasoline",
      "level": ガソリン割合,
      "action": "search_station",
      "severity": "warning"
    }を追加
  ENDIF
  
  IF 水素割合 <= 10 THEN
    「⚠️ 水素残量が少ないです！最寄りの水素ステーションを検索中」と表示。
    水素補給所 = 補給所検索「水素」
    IF 水素補給所["total_found"] > 0 THEN
      「最寄りの水素ステーション: {水素補給所["stations"][0]["name"]}」と表示。
    ENDIF
    燃料管理ログに{
      "timestamp": new Date().toISOString(),
      "event": "low_hydrogen",
      "fuel_type": "hydrogen",
      "level": 水素割合,
      "action": "search_station",
      "severity": "warning"
    }を追加
  ENDIF
  
  IF ディーゼル割合 <= 20 THEN
    「⚠️ ディーゼル残量が少ないです！最寄りのディーゼルスタンドを検索中」と表示。
    ディーゼル補給所 = 補給所検索「ディーゼル」
    IF ディーゼル補給所["total_found"] > 0 THEN
      「最寄りのディーゼルスタンド: {ディーゼル補給所["stations"][0]["name"]}」と表示。
    ENDIF
    燃料管理ログに{
      "timestamp": new Date().toISOString(),
      "event": "low_diesel",
      "fuel_type": "diesel",
      "level": ディーゼル割合,
      "action": "search_station",
      "severity": "warning"
    }を追加
  ENDIF
  
  IF 電気割合 <= 15 THEN
    「⚠️ 電気残量が少ないです！最寄りの充電ステーションを検索中」と表示。
    電気補給所 = 補給所検索「電気」
    IF 電気補給所["total_found"] > 0 THEN
      「最寄りの充電ステーション: {電気補給所["stations"][0]["name"]}」と表示。
    ENDIF
    燃料管理ログに{
      "timestamp": new Date().toISOString(),
      "event": "low_electric",
      "fuel_type": "electric",
      "level": 電気割合,
      "action": "search_station",
      "severity": "warning"
    }を追加
  ENDIF
  
  IF 総走行距離 <= 50 THEN
    「⚠️ 走行可能距離が短いです！補給を推奨します」と表示。
    燃料管理ログに{
      "timestamp": new Date().toISOString(),
      "event": "short_range",
      "total_range": 総走行距離,
      "action": "refuel_recommended",
      "severity": "moderate"
    }を追加
  ENDIF
  
  1000を待つ
ここまで。

「スマート車両燃料管理完了」と表示。
「燃料管理ログ:」と表示。
燃料管理ログを反復
  ログ = 対象
  「  {ログ["timestamp"]}: {ログ["event"]} - {ログ["action"]}」と表示。
ここまで。

「」と表示。

# --- 英語モードでの使用例 ---
「20. 英語モードでの使用例...」と表示。
「言語モード設定」に「english」

# 英語で燃料システム検出
english_fuel = DISCOVER_FUEL_SYSTEMS "all"
PRINT "English fuel systems found: {english_fuelのキー数}"

# 英語でガソリン残量取得
gasoline_level = GET_GASOLINE_LEVEL
PRINT "Gasoline level: {gasoline_level["message"]}"
PRINT "Current gasoline level: {gasoline_level["level"]}L"

# 英語で水素残量取得
hydrogen_level = GET_HYDROGEN_LEVEL
PRINT "Hydrogen level: {hydrogen_level["message"]}"
PRINT "Current hydrogen level: {hydrogen_level["level"]}kg"

# 英語でディーゼル残量取得
diesel_level = GET_DIESEL_LEVEL
PRINT "Diesel level: {diesel_level["message"]}"
PRINT "Current diesel level: {diesel_level["level"]}L"

# 英語で電気残量取得
electric_level = GET_ELECTRIC_LEVEL
PRINT "Electric level: {electric_level["message"]}"
PRINT "Current electric level: {electric_level["level"]}kWh"

# 英語でハイブリッド残量取得
hybrid_level = GET_HYBRID_LEVEL
PRINT "Hybrid level: {hybrid_level["message"]}"
PRINT "Current gasoline level: {hybrid_level["gasoline_level"]}L"
PRINT "Current electric level: {hybrid_level["electric_level"]}kWh"

# 英語で燃料監視開始
monitoring_start = START_FUEL_MONITORING
PRINT "Fuel monitoring started: {monitoring_start["message"]}"
PRINT "Monitoring active: {monitoring_start["monitoring_active"]}"

# 英語で燃料消費率計算
consumption_rate = CALCULATE_FUEL_CONSUMPTION_RATE
PRINT "Fuel consumption rate: {consumption_rate["message"]}"
PRINT "Overall rate: {consumption_rate["overall_rate"]}L/min"

# 英語で走行可能距離予測
driving_range = PREDICT_DRIVING_RANGE
PRINT "Driving range: {driving_range["message"]}"
PRINT "Total range: {driving_range["total_range"]}km"

# 英語で補給所検索
stations = SEARCH_REFUELING_STATIONS "all"
PRINT "Refueling stations: {stations["message"]}"
PRINT "Total stations found: {stations["total_found"]}"

# 英語で最適補給ルート計画
route_plan = PLAN_OPTIMAL_REFUELING_ROUTE "gasoline" "Tokyo"
PRINT "Optimal refueling route: {route_plan["message"]}"
PRINT "Recommended station: {route_plan["route_plan"]["recommended_station"]["name"]}"

# 英語で燃料警告設定
warnings = {
  "low_gasoline": 20,
  "low_hydrogen": 15,
  "low_diesel": 25,
  "low_electric": 20,
  "critical_gasoline": 10,
  "critical_hydrogen": 5,
  "critical_diesel": 15,
  "critical_electric": 10
}
fuel_warnings = SET_FUEL_WARNINGS warnings
PRINT "Fuel warnings: {fuel_warnings["message"]}"

# 英語で燃料履歴取得
fuel_history = GET_FUEL_HISTORY
PRINT "Fuel history: {fuel_history["message"]}"
PRINT "Total records: {fuel_history["total_records"]}"

# 英語で燃料効率評価
efficiency = EVALUATE_FUEL_EFFICIENCY
PRINT "Fuel efficiency: {efficiency["message"]}"
PRINT "Overall assessment: {efficiency["overall_assessment"]}"

# 英語で自動燃料監視
auto_monitoring = AUTO_FUEL_MONITORING
PRINT "Auto fuel monitoring: {auto_monitoring["message"]}"
PRINT "Total measurements: {auto_monitoring["total_measurements"]}"
PRINT "Average gasoline level: {auto_monitoring["average_gasoline_level"]}L"

# 英語で統合燃料管理
integrated_management = INTEGRATED_FUEL_MANAGEMENT
PRINT "Integrated fuel management: {integrated_management["overall_status"]}"
PRINT "Available operations: {integrated_management["available_operations"]のキー数}"

「」と表示。

