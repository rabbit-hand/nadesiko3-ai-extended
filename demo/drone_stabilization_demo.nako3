# --- 自動安定化監視 ---
「16. 自動安定化監視を実行中...」と表示。
自動監視 = 自動安定化監視
「自動安定化監視: {自動監視["message"]}」と表示。
「総計測回数: {自動監視["total_measurements"]}」と表示。
「平均安定性スコア: {自動監視["average_stability_score"]}%」と表示。
「突風検出回数: {自動監視["wind_gust_count"]}」と表示。
「急傾斜検出回数: {自動監視["rapid_tilt_count"]}」と表示。
「進路逸脱検出回数: {自動監視["course_deviation_count"]}」と表示。

「計測結果:」と表示。
自動監視["measurements"]を反復
  計測 = 対象
  「  {計測["timestamp"]}:」と表示。
  「    ジャイロ: ロール={計測["gyro_roll"]}°, ピッチ={計測["gyro_pitch"]}°, ヨー={計測["gyro_yaw"]}°」と表示。
  「    加速度: X={計測["accel_x"]}g, Y={計測["accel_y"]}g, Z={計測["accel_z"]}g」と表示。
  「    姿勢: ロール={計測["attitude_roll"]}°, ピッチ={計測["attitude_pitch"]}°, ヨー={計測["attitude_yaw"]}°」と表示。
  「    突風検出: {計測["wind_gust_detected"]}」と表示。
  「    急傾斜検出: {計測["rapid_tilt_detected"]}」と表示。
  「    進路逸脱検出: {計測["course_deviation_detected"]}」と表示。
  「    安定性スコア: {計測["stability_score"]}%」と表示。
  「---」と表示。
ここまで。

「」と表示。

# --- 実用的な例：突風対応自動安定化 ---
「17. 実用的な例：突風対応自動安定化...」と表示。

# 突風シミュレーションと自動対応
「突風シミュレーションを開始します...」と表示。
安定化ログ = []

20回
  # 全てのセンサーデータを取得
  ジャイロデータ = ジャイロデータ取得
  加速度データ = 加速度データ取得
  姿勢角度 = 姿勢角度取得
  
  # 突風をシミュレート（5回に1回）
  回数_mod = 回数 % 5
  IF 回数_mod = 0 THEN
    「💨 突風発生！」と表示。
    # 突風による急傾斜をシミュレート
    突風検出 = 突風検出
    急傾斜検出 = 急傾斜検出
    
    IF 突風検出["detection"]["gust_detected"] THEN
      「⚠️ 突風を検出！自動水平補正を実行」と表示。
      水平補正 = 自動水平補正
      IF 水平補正["success"] THEN
        「🔄 水平補正完了: ロール補正{水平補正["correction"]["roll_correction"]}°, ピッチ補正{水平補正["correction"]["pitch_correction"]}°」と表示。
        安定化ログに{
          "timestamp": new Date().toISOString(),
          "event": "wind_gust_correction",
          "wind_speed": 突風検出["detection"]["wind_speed"],
          "correction_applied": true,
          "roll_correction": 水平補正["correction"]["roll_correction"],
          "pitch_correction": 水平補正["correction"]["pitch_correction"],
          "severity": "moderate"
        }を追加
      ENDIF
    ENDIF
    
    IF 急傾斜検出["detection"]["tilt_detected"] THEN
      「⚠️ 急傾斜を検出！進路補正を実行」と表示。
      進路補正 = 進路方向復帰
      IF 進路補正["success"] THEN
        「🧭 進路補正完了: ヨー補正{進路補正["correction"]["yaw_correction"]}°」と表示。
        安定化ログに{
          "timestamp": new Date().toISOString(),
          "event": "rapid_tilt_correction",
          "tilt_angle": 急傾斜検出["detection"]["tilt_severity"],
          "correction_applied": true,
          "yaw_correction": 進路補正["correction"]["yaw_correction"],
          "severity": "high"
        }を追加
      ENDIF
    ENDIF
  ENDIF
  
  # 進路逸脱検出（3回に1回）
  進路_mod = 回数 % 3
  IF 進路_mod = 0 THEN
    進路逸脱検出 = 進路逸脱検出
    IF 進路逸脱検出["detection"]["deviation_detected"] THEN
      「🗺️ 進路逸脱を検出！地形追従を実行」と表示。
      地形追従 = 地形追従
      IF 地形追従["success"] THEN
        「🏔️ 地形追従完了: 高度補正{地形追従["correction"]["altitude_correction"]}m」と表示。
        安定化ログに{
          "timestamp": new Date().toISOString(),
          "event": "course_deviation_correction",
          "deviation_distance": 進路逸脱検出["detection"]["deviation"],
          "correction_applied": true,
          "altitude_correction": 地形追従["correction"]["altitude_correction"],
          "severity": "moderate"
        }を追加
      ENDIF
    ENDIF
  ENDIF
  
  # 安定性スコアを表示
  安定性スコア = 姿勢角度["measurement"]["stability_factor"]
  IF 安定性スコア < 70 THEN
    「📊 安定性スコア: {安定性スコア}% (要注意)」と表示。
  ELSE
    「📊 安定性スコア: {安定性スコア}% (良好)」と表示。
  ENDIF
  
  500を待つ
ここまで。

「突風対応自動安定化完了」と表示。
「安定化ログ:」と表示。
安定化ログを反復
  ログ = 対象
  「  {ログ["timestamp"]}: {ログ["event"]} - 重大度: {ログ["severity"]}」と表示。
ここまで。

「」と表示。

# --- 英語モードでの使用例 ---
「18. 英語モードでの使用例...」と表示。
「言語モード設定」に「english」

# 英語で安定化システム検出
english_stabilization = DISCOVER_STABILIZATION_SYSTEMS "all"
PRINT "English stabilization systems found: {english_stabilizationのキー数}"

# 英語でジャイロデータ取得
gyro_data = GET_GYROSCOPE_DATA
PRINT "Gyroscope data: {gyro_data["message"]}"
PRINT "Roll angle: {gyro_data["measurement"]["roll"]}°"

# 英語で加速度データ取得
accel_data = GET_ACCELEROMETER_DATA
PRINT "Accelerometer data: {accel_data["message"]}"
PRINT "X acceleration: {accel_data["measurement"]["x"]}g"

# 英語で地磁気データ取得
magnet_data = GET_MAGNETOMETER_DATA
PRINT "Magnetometer data: {magnet_data["message"]}"
PRINT "Heading: {magnet_data["measurement"]["heading"]}°"

# 英語で姿勢角度取得
attitude_data = GET_ATTITUDE_ANGLES
PRINT "Attitude angles: {attitude_data["message"]}"
PRINT "Roll: {attitude_data["measurement"]["roll"]}°"
PRINT "Stability factor: {attitude_data["measurement"]["stability_factor"]}%"

# 英語で突風検出
wind_gust = DETECT_WIND_GUST
PRINT "Wind gust detection: {wind_gust["message"]}"
PRINT "Wind speed: {wind_gust["detection"]["wind_speed"]}m/s"
PRINT "Gust detected: {wind_gust["detection"]["gust_detected"]}"

# 英語で急傾斜検出
rapid_tilt = DETECT_RAPID_TILT
PRINT "Rapid tilt detection: {rapid_tilt["message"]}"
PRINT "Tilt detected: {rapid_tilt["detection"]["tilt_detected"]}"

# 英語で自動水平補正
level_correction = EXECUTE_AUTO_LEVEL_CORRECTION
PRINT "Auto level correction: {level_correction["message"]}"
PRINT "Roll correction: {level_correction["correction"]["roll_correction"]}°"

# 英語で進路方向復帰
course_correction = EXECUTE_COURSE_CORRECTION
PRINT "Course correction: {course_correction["message"]}"
PRINT "Yaw correction: {course_correction["correction"]["yaw_correction"]}°"

# 英語で地形追従
terrain_following = EXECUTE_TERRAIN_FOLLOWING
PRINT "Terrain following: {terrain_following["message"]}"
PRINT "Altitude correction: {terrain_following["correction"]["altitude_correction"]}m"

# 英語で進路逸脱検出
course_deviation = DETECT_COURSE_DEVIATION
PRINT "Course deviation detection: {course_deviation["message"]}"
PRINT "Deviation detected: {course_deviation["detection"]["deviation_detected"]}"

# 英語で安定化パラメータ設定
parameters = {
  "roll_pid": { "p": 5.0, "i": 0.2, "d": 0.1 },
  "pitch_pid": { "p": 5.0, "i": 0.2, "d": 0.1 },
  "yaw_pid": { "p": 3.0, "i": 0.15, "d": 0.05 }
}
stabilization_params = SET_STABILIZATION_PARAMETERS parameters
PRINT "Stabilization parameters: {stabilization_params["message"]}"

# 英語で安定化履歴取得
stabilization_history = GET_STABILIZATION_HISTORY
PRINT "Stabilization history: {stabilization_history["message"]}"
PRINT "Total records: {stabilization_history["total_records"]}"

# 英語で安定化性能評価
performance = EVALUATE_STABILIZATION_PERFORMANCE
PRINT "Stabilization performance: {performance["message"]}"
PRINT "Overall assessment: {performance["overall_assessment"]}"

# 英語で自動安定化監視
auto_monitoring = AUTO_STABILIZATION_MONITORING
PRINT "Auto stabilization monitoring: {auto_monitoring["message"]}"
PRINT "Total measurements: {auto_monitoring["total_measurements"]}"
PRINT "Average stability score: {auto_monitoring["average_stability_score"]}%"

# 英語で統合安定化管理
integrated_management = INTEGRATED_STABILIZATION_MANAGEMENT
PRINT "Integrated stabilization management: {integrated_management["overall_status"]}"
PRINT "Available operations: {integrated_management["available_operations"]のキー数}"

「」と表示。

# --- 子供向けモードでの使用例 ---
「19. 子供向けモードでの使用例...」と表示。
「かんたんモード」

# 子供向け安定化監視
「🚁 ドローンのじょうたいかんりさん、こんにちは！」と表示。
わんわん

# ジャイロで遊ぶ
「🌀 じゃいろのデータをしらべてみよう！」と表示。
ジャイロデータ = ジャイロデータ取得
ふくふくを「ロールは{ジャイロデータ["measurement"]["roll"]}ど、ピッチは{ジャイロデータ["measurement"]["pitch"]}どだよ！」
ぴよぴよ

# 加速度で遊ぶ
「📊 かそくどのデータをしらべてみよう！」と表示。
加速度データ = 加速度データ取得
ふくふくを「Xかそくどは{加速度データ["measurement"]["x"]}、Yかそくどは{加速度データ["measurement"]["y"]}だよ！」
ぴよぴよ

# 姿勢で遊ぶ
「🎯 しせいのデータをしらべてみよう！」と表示。
姿勢角度 = 姿勢角度取得
ふくふくを「しせいは{姿勢角度["measurement"]["stability_factor"]}%ていどあんてんだよ！」
ぴよぴよ

# 突風で遊ぶ
「💨 たつふうをしらべてみよう！」と表示。
突風検出 = 突風検出
IF 突風検出["detection"]["gust_detected"] THEN
  ふくふくを「たつふうがふいているよ！じょうたいをなおすね！」
  CAT_MEOW
ELSE
  ふくふくを「かぜはだいじょうぶだよ！」
ENDIF

# 傾斜で遊ぶ
「📐 かたむきをしらべてみよう！」と表示。
急傾斜検出 = 急傾斜検出
IF 急傾斜検出["detection"]["tilt_detected"] THEN
  ふくふくを「ドローンがかたむいているよ！なおすね！」
  CAT_MEOW
ELSE
  ふくふくを「ドローンはまっすぐだよ！」
ENDIF

# 水平補正で遊ぶ
「🔄 すいへいにほせいしてみよう！」と表示。
水平補正 = 自動水平補正
IF 水平補正["success"] THEN
  ふくふくを「すいへいにほせいしたよ！びっくりだね！」
  CAT_MEOW
ELSE
  ふくふくを「ほせいできなかったよ！」
ENDIF

# 進路補正で遊ぶ
「🧭 しんろをほせいしてみよう！」と表示。
進路補正 = 進路方向復帰
IF 進路補正["success"] THEN
  ふくふくを「しんろをほせいしたよ！かしこいね！」
  CAT_MEOW
ELSE
  ふくふくを「しんろをほせいできなかったよ！」
ENDIF

# 地形追従で遊ぶ
「🏔️ ちけいについていってみよう！」と表示。
地形追従 = 地形追従
IF 地形追従["success"] THEN
  ふくふくを「ちけいについていけるよ！すごいね！」
  CAT_MEOW
ELSE
  ふくふくを「ちけいについていけなかったよ！」
ENDIF

「」と表示。

# --- 高度な機能：PIDチューニング ---
「20. 高度な機能：PIDチューニング...」と表示。

# PIDパラメータの最適化テスト
「PIDパラメータ最適化テストを実行中...」と表示。
最適化結果 = []

# 異なるPIDパラメータセットをテスト
3回
  パラメータセット = [
    { "roll_pid": { "p": 3.0, "i": 0.1, "d": 0.05 }, "pitch_pid": { "p": 3.0, "i": 0.1, "d": 0.05 }, "yaw_pid": { "p": 2.0, "i": 0.1, "d": 0.0 } },
    { "roll_pid": { "p": 5.0, "i": 0.2, "d": 0.1 }, "pitch_pid": { "p": 5.0, "i": 0.2, "d": 0.1 }, "yaw_pid": { "p": 3.0, "i": 0.15, "d": 0.05 } },
    { "roll_pid": { "p": 7.0, "i": 0.3, "d": 0.15 }, "pitch_pid": { "p": 7.0, "i": 0.3, "d": 0.15 }, "yaw_pid": { "p": 4.0, "i": 0.2, "d": 0.1 } }
  ]
  
  現在パラメータ = パラメータセット[回数]
  パラメータ設定 = 安定化パラメータ設定 現在パラメータ
  
  「パラメータセット {回数 + 1} をテスト中...」と表示。
  
  # 10回の安定性テスト
  テスト結果 = []
  10回
    姿勢角度 = 姿勢角度取得
    安定性スコア = 姿勢角度["measurement"]["stability_factor"]
    テスト結果に安定性スコアを追加
    100を待つ
  ここまで。
  
  平均安定性 = テスト結果から平均
  最小安定性 = テスト結果から最小
  最大安定性 = テスト結果から最大
  
  最適化結果に{
    "parameter_set": 回数 + 1,
    "roll_p": 現在パラメータ["roll_pid"]["p"],
    "pitch_p": 現在パラメータ["pitch_pid"]["p"],
    "yaw_p": 現在パラメータ["yaw_pid"]["p"],
    "average_stability": 平均安定性,
    "min_stability": 最小安定性,
    "max_stability": 最大安定性
  }を追加
  
  「  平均安定性: {平均安定性.toFixed(1)}%」と表示。
  「  最小安定性: {最小安定性.toFixed(1)}%」と表示。
  「  最大安定性: {最大安定性.toFixed(1)}%」と表示。
  
  500を待つ
ここまで。

# 最適なパラメータを選択
最適結果 = 最適化結果から「average_stability」を最大
「最適なパラメータセット: {最適結果["parameter_set"]}」と表示。
「最適安定性: {最適結果["average_stability"].toFixed(1)}%」と表示。

# 最適パラメータを再設定
最適パラメータ = パラメータセット[最適結果["parameter_set"] - 1]
最終設定 = 安定化パラメータ設定 最適パラメータ
「最適PIDパラメータを設定しました」と表示。

「」と表示。

