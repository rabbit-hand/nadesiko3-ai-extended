# --- 英語モードでの使用例 ---
「25. 英語モードでの使用例...」と表示。
「言語モード設定」に「english」

# 英語でNumPy
english_numpy = CREATE_NUMPY_ARRAY [1, 2, 3, 4, 5]
PRINT "English NumPy array: {english_numpy["message"]}"
PRINT "Array shape: {english_numpy["array"]["shape"]を「,」で区切って表示}"

# 英語でPandas
english_pandas = CREATE_PANDAS_DATAFRAME [
  {"name": "Alice", "age": 25, "city": "Tokyo"},
  {"name": "Bob", "age": 30, "city": "Osaka"}
]
PRINT "English Pandas: {english_pandas["message"]}"
PRINT "DataFrame shape: {english_pandas["dataframe"]["shape"]を「,」で区切って表示}"

# 英語でMatplotlib
english_plot = CREATE_MATPLOTLIB_PLOT [10, 20, 30, 40, 50] "line_plot"
PRINT "English Matplotlib: {english_plot["message"]}"
PRINT "Plot type: {english_plot["plot"]["type"]}"

# 英語でScikit-learn
english_ml = TRAIN_SCIKIT_LEARN_MODEL [
  {"features": [1, 2], "label": 0},
  {"features": [3, 4], "label": 1}
] "svm"
PRINT "English Scikit-learn: {english_ml["message"]}"
PRINT "Accuracy: {english_ml["model"]["accuracy"]}%"

# 英語でTensorFlow
english_tf = CREATE_TENSORFLOW_MODEL
PRINT "English TensorFlow: {english_tf["message"]}"
PRINT "Framework: {english_tf["model"]["framework"]}"

# 英語でPyTorch
english_pytorch = CREATE_PYTORCH_MODEL
PRINT "English PyTorch: {english_pytorch["message"]}"
PRINT "Framework: {english_pytorch["model"]["framework"]}"

# 英語でOpenCV
english_cv = PROCESS_OPENCV_IMAGE {"width": 640, "height": 480} "edge_detection"
PRINT "English OpenCV: {english_cv["message"]}"
PRINT "Processing time: {english_cv["result"]["processing_time"]}ms"

# 英語でNLTK
english_nltk = PROCESS_NLTK_TEXT "This is a test of natural language processing." "tokenization"
PRINT "English NLTK: {english_nltk["message"]}"
PRINT "Processing time: {english_nltk["result"]["processing_time"]}ms"

# 英語でspaCy
english_spacy = PROCESS_SPACY_TEXT "Natural language processing with spaCy."
PRINT "English spaCy: {english_spacy["message"]}"
PRINT "Tokens: {english_spacy["result"]["tokens"]のキー数}"

# 英語でFlask
english_flask = CREATE_FLASK_APP
PRINT "English Flask: {english_flask["message"]}"
PRINT "App name: {english_flask["app"]["name"]}"

# 英語でDjango
english_django = CREATE_DJANGO_PROJECT
PRINT "English Django: {english_django["message"]}"
PRINT "Project name: {english_django["project"]["name"]}"

# 英語でRequests
english_requests = MAKE_HTTP_REQUEST "https://api.example.com" "get"
PRINT "English Requests: {english_requests["message"]}"
PRINT "Status code: {english_requests["response"]["status_code"]}"

# 英語でBeautifulSoup
english_bs = PARSE_HTML "<html><body><h1>Hello</h1></body></html>"
PRINT "English BeautifulSoup: {english_bs["message"]}"
PRINT "Title: {english_bs["result"]["title"]}"

# 英語でSciPy
english_scipy = PERFORM_SCIPY_OPERATION [1, 2, 3, 4, 5] "optimize"
PRINT "English SciPy: {english_scipy["message"]}"
PRINT "Minimum: {english_scipy["result"]["output"]["minimum"]}"

# 英語でPillow
english_pillow = PROCESS_PILLOW_IMAGE {"width": 800, "height": 600} "resize"
PRINT "English Pillow: {english_pillow["message"]}"
PRINT "Output size: {english_pillow["result"]["output_image"]["width"]}x{english_pillow["result"]["output_image"]["height"]}"

# 英語でPygame
english_pygame = CREATE_PYGAME
PRINT "English Pygame: {english_pygame["message"]}"
PRINT "Screen size: {english_pygame["game"]["screen_size"]を「,」で区切って表示}"

# 英語でTkinter
english_tkinter = CREATE_TKINTER_GUI
PRINT "English Tkinter: {english_tkinter["message"]}"
PRINT "Window size: {english_tkinter["gui"]["size"]を「,」で区切って表示}"

# 英語でSQLite
english_sqlite = OPERATE_SQLITE "test.db" "create"
PRINT "English SQLite: {english_sqlite["message"]}"
PRINT "Execution time: {english_sqlite["result"]["execution_time"]}ms"

# 英語でテスト
english_tests = RUN_PYTHON_TESTS
PRINT "English Tests: {english_tests["message"]}"
PRINT "Total tests: {english_tests["results"]["total_tests"]}"

# 英語でコード実行
english_code = EXECUTE_PYTHON_CODE "print('Hello from Python!')"
PRINT "English Code Execution: {english_code["message"]}"
PRINT "Output: {english_code["result"]["output"]["stdout"]}"

# 英語でパッケージインストール
english_package = INSTALL_PYTHON_PACKAGE "requests"
PRINT "English Package Install: {english_package["message"]}"
PRINT "Package version: {english_package["result"]["version"]}"

# 英語で互換状態
english_status = GET_PYTHON_COMPATIBILITY_STATUS
PRINT "English Compatibility: {english_status["overall_compatibility"]}%"

「」と表示。

