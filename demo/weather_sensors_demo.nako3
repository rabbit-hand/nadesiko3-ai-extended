# --- 実用的な例：スマートホーム気象管理 ---
「16. 実用的な例：スマートホーム気象管理...」と表示。

# 連続監視を開始
「スマートホーム気象監視を開始します...」と表示。
監視ログ = []

10回
  # 全てのセンサーを計測
  温度 = 温度計測
  体温 = 体温計測
  気温 = 気温計測
  湿度 = 湿度計測
  風量 = 風量計測
  天気 = 天気観測
  
  # 異常検出
  異常 = 異常温度検出
  
  # 熱中症評価
  熱中症 = 熱中症警告
  
  # 自動制御判断
  IF 異常["abnormal_detected"] THEN
    「⚠️ 異常な温度を検出！エアコンを自動調整します」と表示。
    監視ログに{
      "timestamp": new Date().toISOString(),
      "event": "abnormal_temperature",
      "temperature": 異常["temperature"],
      "action": "auto_adjust_ac",
      "severity": 異常["severity"]
    }を追加
  ENDIF
  
  IF 熱中症["risk_level"] = "high" OR 熱中症["risk_level"] = "extreme" THEN
    「🚨 高い熱中症リスク！冷房を強化します」と表示。
    監視ログに{
      "timestamp": new Date().toISOString(),
      "event": "heat_stroke_risk",
      "risk_level": 熱中症["risk_level"],
      "action": "increase_cooling",
      "heat_index": 熱中症["heat_index"]
    }を追加
  ENDIF
  
  IF 天気["observation"]["weather_condition"] = "rainy" THEN
    「🌧 雨が降っています！窓を閉めます」と表示。
    監視ログに{
      "timestamp": new Date().toISOString(),
      "event": "rain_detected",
      "weather": 天気["observation"]["weather_condition"],
      "action": "close_windows"
    }を追加
  ENDIF
  
  IF 風量["measurement"]["wind_speed"] > 15 THEN
    「💨 強風検出！外出を注意してください」と表示。
    監視ログに{
      "timestamp": new Date().toISOString(),
      "event": "strong_wind",
      "wind_speed": 風量["measurement"]["wind_speed"],
      "action": "alert_strong_wind"
    }を追加
  ENDIF
  
  2000を待つ
ここまで。

「スマートホーム気象監視完了」と表示。
「監視ログ:」と表示。
監視ログを反復
  ログ = 対象
  「  {ログ["timestamp"]}: {ログ["event"]} - {ログ["action"]}」と表示。
ここまで。

「」と表示。

# --- 英語モードでの使用例 ---
「17. 英語モードでの使用例...」と表示。
「言語モード設定」に「english」

# 英語で温度センサーシステム検出
english_sensors = DISCOVER_WEATHER_SENSORS "all"
PRINT "English weather sensors found: {english_sensorsのキー数}"

# 英語で温度計測
temp_measurement = MEASURE_TEMPERATURE
PRINT "Temperature measurement: {temp_measurement["message"]}"
PRINT "Current temperature: {temp_measurement["measurement"]["temperature"]}°C"

# 英語で体温計測
body_temp = MEASURE_BODY_TEMPERATURE
PRINT "Body temperature: {body_temp["message"]}"
PRINT "Current body temperature: {body_temp["measurement"]["body_temperature"]}°C"

# 英語で気温計測
air_temp = MEASURE_AIR_TEMPERATURE
PRINT "Air temperature: {air_temp["message"]}"
PRINT "Current air temperature: {air_temp["measurement"]["air_temperature"]}°C"

# 英語で風量計測
wind_measurement = MEASURE_WIND
PRINT "Wind measurement: {wind_measurement["message"]}"
PRINT "Current wind speed: {wind_measurement["measurement"]["wind_speed"]}m/s"
PRINT "Wind direction: {wind_measurement["measurement"]["wind_direction"]}°"

# 英語で湿度計測
humidity_measurement = MEASURE_HUMIDITY
PRINT "Humidity measurement: {humidity_measurement["message"]}"
PRINT "Current humidity: {humidity_measurement["measurement"]["humidity"]}%"

# 英語で気圧計測
pressure_measurement = MEASURE_PRESSURE
PRINT "Pressure measurement: {pressure_measurement["message"]}"
PRINT "Current pressure: {pressure_measurement["measurement"]["pressure"]}hPa"

# 英語で天気観測
weather_obs = OBSERVE_WEATHER
PRINT "Weather observation: {weather_obs["message"]}"
PRINT "Weather condition: {weather_obs["observation"]["weather_condition"]}"
PRINT "Air temperature: {weather_obs["observation"]["air_temperature"]}°C"
PRINT "Humidity: {weather_obs["observation"]["humidity"]}%"
PRINT "Wind speed: {weather_obs["observation"]["wind_speed"]}m/s"

# 英語で天気予報取得
forecast = GET_WEATHER_FORECAST
PRINT "Weather forecast: {forecast["message"]}"
PRINT "Forecast days: {forecast["forecasts"]のキー数}"

# 英語で異常温度検出
abnormal_temp = DETECT_ABNORMAL_TEMPERATURE
PRINT "Abnormal temperature detection: {abnormal_temp["message"]}"
PRINT "Abnormal detected: {abnormal_temp["abnormal_detected"]}"

# 英語で熱中症警告
heat_stroke = ASSESS_HEAT_STROKE
PRINT "Heat stroke assessment: {heat_stroke["message"]}"
PRINT "Risk level: {heat_stroke["risk_level"]}"
PRINT "Recommendations: {heat_stroke["recommendations"]}"

# 英語で温度履歴取得
temp_history = GET_TEMPERATURE_HISTORY
PRINT "Temperature history: {temp_history["message"]}"
PRINT "Total records: {temp_history["total_records"]}"

# 英語で天気データ記録
weather_record = RECORD_WEATHER_DATA
PRINT "Weather data record: {weather_record["message"]}"
PRINT "Record ID: {weather_record["record"]["record_id"]}"

# 英語で自動気象監視
auto_monitor = AUTO_WEATHER_MONITORING
PRINT "Auto weather monitoring: {auto_monitor["message"]}"
PRINT "Total measurements: {auto_monitor["total_measurements"]}"
PRINT "Average temperature: {auto_monitor["average_temperature"]}°C"

# 英語で統合気象監視
integrated_monitor = INTEGRATED_WEATHER_MONITORING
PRINT "Integrated weather monitoring: {integrated_monitor["overall_status"]}"
PRINT "Available operations: {integrated_monitor["available_operations"]のキー数}"

「」と表示。

# --- 子供向けモードでの使用例 ---
「18. 子供向けモードでの使用例...」と表示。
「かんたんモード」

# 子供向け温度計測
「🌡️ おんどけいさん、こんにちは！」と表示。
わんわん

# 温度で遊ぶ
「🌡️ おんどけいをはかってみよう！」と表示。
温度計測 = 温度計測
ふくふくを「いまのおんどは{温度計測["measurement"]["temperature"]}どだよ！」
ぴよぴよ

# 体温で遊ぶ
「🤒 たいおんをはかってみよう！」と表示。
体温計測 = 体温計測
IF 体温計測["measurement"]["status"] = "normal" THEN
  ふくふくを「たいおんはげんきだよ！」
  CAT_MEOW
ELSE
  ふくふくを「たいおんがちょっとあぶないかも！」
ENDIF

# 天気で遊ぶ
「☀️ てんきをしらべてみよう！」と表示。
天気観測 = 天気観測
天気状態 = 天気観測["observation"]["weather_condition"]

IF 天気状態 = "clear" THEN
  ふくふくを「きょうははれだよ！そとあそぼう！」
  にゃんにゃん
ELSE IF 天気状態 = "rainy" THEN
  ふくふくを「あめがふってるよ！かさをもってね！」
ELSE IF 天気状態 = "cloudy" THEN
  ふくふくを「くもってるよ！おてんきがいいかも！」
ELSE
  ふくふくを「てんきは{天気状態}だよ！」
ENDIF

# 風で遊ぶ
「💨 かぜのつよさをしらべてみよう！」と表示。
風量計測 = 風量計測
風速 = 風量計測["measurement"]["wind_speed"]
風状態 = 風量計測["measurement"]["status"]

IF 風速 < 3 THEN
  ふくふくを「かぜはしずかだよ！」
ELSE IF 風速 < 8 THEN
  ふくふくを「かぜがふいてるよ！」
ELSE
  ふくふくを「かぜがつよいよ！そとにでないでね！」
ENDIF

# 熱中症で遊ぶ
「🌡️ ねっちゅうしょうリスクをしらべよう！」と表示。
熱中症警告 = 熱中症警告
リスク = 熱中症警告["risk_level"]

IF リスク = "low" THEN
  ふくふくを「ねっちゅうしょうリスクはひくいよ！げんきにあそぼう！」
ELSE IF リスク = "moderate" THEN
  ふくふくを「みずをのんでね！」
ELSE IF リスク = "high" THEN
  ふくふくを「そとであそぶのはやめてね！れいぼうですずしく！」
ELSE
  ふくふくを「あぶないからへやのなかでね！」
ENDIF

「」と表示。

# --- 高度な機能：気象データ分析 ---
「19. 高度な機能：気象データ分析...」と表示。

# 24時間のデータを収集
「24時間の気象データを収集中...」と表示。
分析データ = []

24回
  # 全ての計測を実行
  温度 = 温度計測
  気温 = 気温計測
  湿度 = 湿度計測
  風量 = 風量計測
  天気 = 天気観測
  
  分析データに{
    "hour": 分析データのキー数 + 1,
    "timestamp": new Date().toISOString(),
    "temperature": 温度["measurement"]["temperature"],
    "air_temperature": 気温["measurement"]["air_temperature"],
    "humidity": 湿度["measurement"]["humidity"],
    "wind_speed": 風量["measurement"]["wind_speed"],
    "weather_condition": 天気["observation"]["weather_condition"]
  }を追加
  
  500を待つ
ここまで。

# データ分析
「気象データ分析結果:」と表示。

# 平均値計算
平均温度 = 分析データから「temperature」を平均
平均気温 = 分析データから「air_temperature」を平均
平均湿度 = 分析データから「humidity」を平均
平均風速 = 分析データから「wind_speed」を平均

「  平均温度: {平均温度.toFixed(1)}°C」と表示。
「  平均気温: {平均気温.toFixed(1)}°C」と表示。
「  平均湿度: {平均湿度.toFixed(1)}%」と表示。
「  平均風速: {平均風速.toFixed(1)}m/s」と表示。

# 最大値・最小値
最高温度 = 分析データから「temperature」を最大
最低温度 = 分析データから「temperature」を最小
最高風速 = 分析データから「wind_speed」を最大

「  最高温度: {最高温度.toFixed(1)}°C」と表示。
「  最低温度: {最低温度.toFixed(1)}°C」と表示。
「  最高風速: {最高風速.toFixed(1)}m/s」と表示。

# 天気パターン分析
天気カウント = {}
分析データを反復
  天気 = 対象["weather_condition"]
  IF 天気カウント[天気] = 未定義 THEN
    天気カウント[天気] = 0
  ENDIF
  天気カウント[天気] = 天気カウント[天気] + 1
ここまで。

「  天気パターン:」と表示。
天気カウントを反復
  天気 = 対象.key
  回数 = 対象.value
  「    {天気}: {回数}回 ({(回数/24*100).toFixed(1)}%)」と表示。
ここまで。

