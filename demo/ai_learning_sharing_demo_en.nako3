      "final_node_count": network_log.length > 0 ? network_log[network_log.length - 1]["node_count"] : 0,
      "final_success_rate": network_log.length > 0 ? network_log[network_log.length - 1]["success_rate"] : 0
    },
    "overall_performance": ai_performance["performance"]["overall_score"]
