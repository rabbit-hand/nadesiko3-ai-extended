PRINT "  Network iterations: {ai_learning_report["statistics"]["network_summary"]["total_iterations"]}"
PRINT "  Final network nodes: {ai_learning_report["statistics"]["network_summary"]["final_node_count"]}"
PRINT "  Recommendations: {ai_learning_report["optimization_recommendations"].length} items"

